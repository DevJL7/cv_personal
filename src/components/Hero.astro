---
import { Github, Linkedin } from 'lucide-astro';
import AnimatedReveal from './motion/AnimatedReveal.astro';
import TerminalPreview from './TerminalPreview.astro';
import { site } from '../data/site';

const typewriterPhrases = [
  site.roleFocus ?? 'Frontend · UX · producto digital',
  'React · TypeScript · Astro',
  'Código limpio · interfaces claras',
  'Autodidacta · IA-assisted dev',
];
---

<section
  id="hero"
  class="relative min-h-[calc(100dvh-7rem)] py-10 lg:py-16"
  aria-labelledby="hero-heading"
>
  <!-- Grid decorativo estilo IDE -->
  <div class="hero-grid pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true"></div>

  <div class="relative grid items-center gap-12 lg:grid-cols-2 lg:gap-14 xl:gap-20">
    <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
      <AnimatedReveal>
        <p class="mb-3 font-mono text-sm text-muted">Hola, soy</p>
        <h1
          id="hero-heading"
          class="text-4xl font-semibold tracking-tight sm:text-5xl xl:text-[3.5rem] xl:leading-[1.08]"
        >
          <span class="text-gradient">{site.name}</span>
        </h1>
      </AnimatedReveal>

      <AnimatedReveal delay={0.05}>
        <p class="mt-4 text-xl font-medium text-gradient-accent sm:text-2xl">
          {site.role}
        </p>
        <p class="mt-2 flex min-h-[1.75rem] items-center justify-center font-mono text-sm text-muted sm:text-base lg:justify-start">
          <span
            class="typewriter-text text-accent/90"
            data-typewriter
            data-phrases={JSON.stringify(typewriterPhrases)}
            aria-live="polite"
          ></span>
          <span class="typewriter-cursor ml-0.5 text-accent" aria-hidden="true">|</span>
        </p>
      </AnimatedReveal>

      <AnimatedReveal delay={0.08}>
        <p class="mt-6 max-w-md text-base leading-relaxed text-muted sm:text-lg">
          {site.heroLead ?? site.tagline}
        </p>
      </AnimatedReveal>

      <AnimatedReveal delay={0.1}>
        <dl
          class="mt-6 flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm text-muted-foreground lg:justify-start"
        >
          <div>
            <dt class="sr-only">Ubicación</dt>
            <dd>{site.location}</dd>
          </div>
          {
            site.employer && (
              <>
                <span class="text-border" aria-hidden="true">·</span>
                <div>
                  <dt class="sr-only">Empresa</dt>
                  <dd>{site.employer}</dd>
                </div>
              </>
            )
          }
        </dl>
      </AnimatedReveal>

      <AnimatedReveal delay={0.12}>
        <div
          class="mt-8 flex flex-wrap items-center justify-center gap-3 lg:justify-start"
        >
          <a
            href={site.cvPdfPath}
            download
            data-magnetic
            data-magnetic-strength="0.25"
            class="btn-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          >
            Descargar CV
          </a>
          <div class="flex gap-2">
            {
              site.social.map((link) => {
                const Icon = link.icon === 'github' ? Github : Linkedin;
                return (
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-ghost focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/50"
                    aria-label={link.label}
                  >
                    <Icon class="size-5" aria-hidden="true" />
                  </a>
                );
              })
            }
          </div>
        </div>
      </AnimatedReveal>
    </div>

    <AnimatedReveal delay={0.1} class="w-full lg:max-w-xl lg:justify-self-end" variant="fade-right">
      <p class="mb-3 hidden font-mono text-xs text-muted-foreground lg:block">
        Consola interactiva
      </p>
      <TerminalPreview />
      <p class="mt-3 text-center font-mono text-xs text-muted-foreground lg:text-left">
        Prueba <kbd class="kbd text-accent">help</kbd>
        <span class="mx-1 text-border">·</span>
        pulsa <kbd class="kbd">Enter</kbd>
      </p>
    </AnimatedReveal>
  </div>

  <a
    href="#about"
    class="scroll-indicator group mx-auto mt-10 flex w-fit flex-col items-center gap-2 lg:mt-12"
    aria-label="Ir a la sección de perfil"
  >
    <span class="scroll-indicator-mouse scroll-cue">
      <span class="scroll-indicator-wheel"></span>
    </span>
    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground transition-colors group-hover:text-accent">
      Explorar
    </span>
  </a>
</section>
