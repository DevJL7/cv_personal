---
import { Github, Linkedin } from 'lucide-astro';
import '../styles/global.css';
import ThemeToggle from './ui/ThemeToggle.astro';
import CommandPalette from './CommandPalette.astro';
import DevCursor from './DevCursor.astro';
import DevStatusBar from './DevStatusBar.astro';
import Seo from './Seo.astro';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.seo.title,
  description = site.seo.description,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

const navItems = [
  { href: '#about', label: 'Perfil' },
  { href: '#experience', label: 'Experiencia' },
  { href: '#projects', label: 'Proyectos' },
  { href: '#skills', label: 'Skills' },
] as const;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />

    <Seo title={title} description={description} canonicalURL={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- FOUC: debe ser inline; clave sincronizada con STORAGE_KEYS.theme -->
    <script is:inline>
      (function () {
        var key = 'cv-theme';
        var stored = localStorage.getItem(key);
        var theme = stored === 'light' || stored === 'dark' ? stored : 'dark';
        document.documentElement.classList.remove('dark', 'light');
        document.documentElement.classList.add(theme);
      })();
    </script>
  </head>
  <body class="min-h-screen has-status-bar">
    <DevCursor />
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-xl focus:bg-accent focus:px-4 focus:py-2 focus:text-white"
    >
      Saltar al contenido
    </a>

    <header
      class="site-header fixed inset-x-0 top-0 z-50 border-b border-border/40 bg-background/75 backdrop-blur-xl backdrop-saturate-150"
    >
      <nav
        class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3.5 sm:px-6 sm:py-4"
        aria-label="Principal"
      >
        <a
          href="/"
          class="font-mono text-sm font-medium text-foreground transition-opacity hover:opacity-75"
        >
          {site.name.split(' ')[0]}<span class="text-accent">.</span>dev
        </a>

        <div class="flex items-center gap-2 sm:gap-4">
          <ul class="hidden items-center gap-6 text-sm md:flex">
            {
              navItems.map(({ href, label }) => (
                <li>
                  <a href={href} class="nav-link" data-nav={href}>
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
          <ThemeToggle />
        </div>
      </nav>
    </header>

    <main id="main" class="mx-auto max-w-6xl px-5 pb-32 pt-24 sm:px-6 sm:pt-28">
      <slot />
    </main>

    <footer class="border-t border-border/40 bg-background-subtle/50 py-14">
      <div class="mx-auto max-w-6xl px-5 sm:px-6">
        <div
          class="flex flex-col items-center justify-between gap-8 sm:flex-row sm:items-start"
        >
          <div class="text-center sm:text-left">
            <p class="font-medium text-foreground">{site.name}</p>
            <p class="mt-1 text-sm text-muted">{site.role}</p>
            <p class="mt-3 font-mono text-xs text-muted-foreground">
              {site.location}
            </p>
          </div>

          <div class="flex flex-col items-center gap-4 sm:items-end">
            <div class="flex gap-2">
              {
                site.social.map((link) => {
                  const Icon = link.icon === 'github' ? Github : Linkedin;
                  return (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn-ghost !size-10"
                      aria-label={link.label}
                    >
                      <Icon class="size-4" aria-hidden="true" />
                    </a>
                  );
                })
              }
            </div>
            <p class="text-xs text-muted-foreground">
              © {new Date().getFullYear()} · Astro + TypeScript
            </p>
          </div>
        </div>
      </div>
    </footer>

    <div
      class="scroll-progress"
      aria-hidden="true"
    >
      <div class="scroll-progress-bar" data-scroll-progress></div>
    </div>

    <button
      type="button"
      class="back-to-top"
      data-back-to-top
      aria-label="Volver arriba"
      aria-hidden="true"
      tabindex="-1"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 19V5"></path>
        <path d="m5 12 7-7 7 7"></path>
      </svg>
    </button>

    <CommandPalette />
    <DevStatusBar />

    <script>
      import { initClient } from '../lib/init-client.ts';

      initClient();
      document.addEventListener('astro:page-load', initClient);
    </script>
  </body>
</html>
