---
import AnimatedReveal from '../motion/AnimatedReveal.astro';

interface Props {
  label: string;
  title: string;
  description?: string;
  id?: string;
}

const { label, title, description, id } = Astro.props;
---

<AnimatedReveal variant="blur-up">
  <header class="mb-14 max-w-2xl">
    <p class="section-label mb-4">{label}</p>
    <h2
      id={id}
      class="text-3xl font-semibold tracking-tight text-foreground sm:text-4xl"
    >
      {title}
    </h2>
    {
      description && (
        <p class="mt-4 text-base leading-relaxed text-muted sm:text-lg">
          {description}
        </p>
      )
    }
  </header>
</AnimatedReveal>
