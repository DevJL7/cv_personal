---
import { Moon, Sun } from 'lucide-astro';
---

<button
  type="button"
  id="theme-toggle"
  class="btn-ghost group relative !size-10"
  aria-label="Cambiar tema claro/oscuro"
>
  <Moon
    class="size-4 transition-all duration-300 ease-out dark:scale-75 dark:opacity-0"
    aria-hidden="true"
  />
  <Sun
    class="absolute size-4 scale-75 opacity-0 transition-all duration-300 ease-out dark:scale-100 dark:opacity-100"
    aria-hidden="true"
  />
</button>
